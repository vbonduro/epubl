{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "epubl",
  "version": "0.1.0",
  "identifier": "dev.epubl.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "epubl",
        "width": 900,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "PLACEHOLDER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/vbonduro/epubl/releases/latest/download/latest.json"
      ]
    }
  }
}
