{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "epubl",
  "version": "0.1.0",
  "identifier": "dev.epubl.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "epubl",
        "width": 900,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Vincent Bonduro",
    "copyright": "© 2025 epubl contributors",
    "category": "Utility",
    "shortDescription": "Transfer epub books to your eReader",
    "longDescription": "epubl makes it easy to sync your epub library to your Kindle, Kobo, or other eReader. Connect your device, select books, and click Sync.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "epubl"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1NUEzMUU2NjUwRkYzOUMKUldTYzh3OWw1akZhWmZST3g5RXY0clpqcHZwSUk1bE9XbG4vMGNBQTVmV2FHdElaSmZCUnVwb20K",
      "endpoints": [
        "https://github.com/vbonduro/epubl/releases/latest/download/latest.json"
      ]
    }
  }
}
